# Suricata ruleset — hping3 DoS detection and mitigation
# Covers attacks from dos_hping3.sh:
#   1. SYN flood on port 80  (--syn --flood --rand-source)
#   2. SYN flood on port 443 (--syn --flood --rand-source)
#   3. UDP flood on port 53  (--udp --flood --rand-source)
#
# Rule actions:
#   alert = log only (IDS mode)
#   drop  = block + log (IPS mode, requires Suricata inline/nfqueue)
#
# Deploy: add this file to suricata.yaml under rule-files, then:
#   sudo suricata-update
#   sudo systemctl reload suricata
# -------------------------------------------------------

# -------------------------------------------------------
# SECTION 1: hping3 FINGERPRINT DETECTION
# hping3 defaults: TCP window=512, TTL=64, no TCP options
# These rules identify hping3 specifically regardless of rate
# -------------------------------------------------------

alert tcp any any -> $HOME_NET [80,443] (
    msg:"HPING3 FINGERPRINT - SYN with default window and TTL";
    flags:S,SA;
    window:512;
    ttl:64;
    classtype:attempted-dos;
    sid:9000001; rev:1;
)

drop tcp any any -> $HOME_NET [80,443] (
    msg:"HPING3 FINGERPRINT DROP - SYN flood hping3 signature";
    flags:S,SA;
    window:512;
    ttl:64;
    threshold:type both, track by_dst, count 50, seconds 5;
    classtype:attempted-dos;
    sid:9000002; rev:1;
)

# -------------------------------------------------------
# SECTION 2: SYN FLOOD — ports 80 and 443
# flags:S,SA = SYN bit set, ACK bit NOT set (pure SYN only)
# detection_filter triggers after threshold is exceeded
# -------------------------------------------------------

alert tcp any any -> $HOME_NET 80 (
    msg:"DOS SYN FLOOD ALERT - HTTP port 80 high SYN rate";
    flags:S,SA;
    detection_filter:track by_dst, count 200, seconds 1;
    classtype:attempted-dos;
    sid:9000003; rev:1;
)

drop tcp any any -> $HOME_NET 80 (
    msg:"DOS SYN FLOOD DROP - HTTP port 80";
    flags:S,SA;
    detection_filter:track by_dst, count 500, seconds 1;
    classtype:attempted-dos;
    sid:9000004; rev:1;
)

alert tcp any any -> $HOME_NET 443 (
    msg:"DOS SYN FLOOD ALERT - HTTPS port 443 high SYN rate";
    flags:S,SA;
    detection_filter:track by_dst, count 200, seconds 1;
    classtype:attempted-dos;
    sid:9000005; rev:1;
)

drop tcp any any -> $HOME_NET 443 (
    msg:"DOS SYN FLOOD DROP - HTTPS port 443";
    flags:S,SA;
    detection_filter:track by_dst, count 500, seconds 1;
    classtype:attempted-dos;
    sid:9000006; rev:1;
)

# Catch-all SYN flood to any port on the host
drop tcp any any -> $HOME_NET any (
    msg:"DOS SYN FLOOD DROP - high SYN rate any port";
    flags:S,SA;
    detection_filter:track by_dst, count 1000, seconds 1;
    classtype:attempted-dos;
    sid:9000007; rev:1;
)

# -------------------------------------------------------
# SECTION 3: UDP FLOOD — port 53 (DNS)
# hping3 --udp --flood --rand-source -p 53
# -------------------------------------------------------

alert udp any any -> $HOME_NET 53 (
    msg:"DOS UDP FLOOD ALERT - DNS port 53 high rate";
    detection_filter:track by_dst, count 500, seconds 1;
    classtype:attempted-dos;
    sid:9000008; rev:1;
)

drop udp any any -> $HOME_NET 53 (
    msg:"DOS UDP FLOOD DROP - DNS port 53";
    detection_filter:track by_dst, count 1000, seconds 1;
    classtype:attempted-dos;
    sid:9000009; rev:1;
)

# Catch-all UDP flood to any port
drop udp any any -> $HOME_NET any (
    msg:"DOS UDP FLOOD DROP - high UDP rate any port";
    detection_filter:track by_dst, count 2000, seconds 1;
    classtype:attempted-dos;
    sid:9000010; rev:1;
)

# -------------------------------------------------------
# SECTION 4: HALF-OPEN CONNECTION EXHAUSTION
# Detects SYN-RECV state buildup — complementary to rate rules
# Fires when a single source sends repeated SYNs with no handshake
# (less useful with --rand-source but catches non-spoofed variants)
# -------------------------------------------------------

alert tcp any any -> $HOME_NET [80,443] (
    msg:"DOS HALF-OPEN EXHAUSTION - repeated SYN no handshake";
    flags:S,SA;
    threshold:type threshold, track by_src, count 100, seconds 10;
    classtype:attempted-dos;
    sid:9000011; rev:1;
)

drop tcp any any -> $HOME_NET [80,443] (
    msg:"DOS HALF-OPEN EXHAUSTION DROP - repeated SYN no handshake";
    flags:S,SA;
    threshold:type threshold, track by_src, count 200, seconds 10;
    classtype:attempted-dos;
    sid:9000012; rev:1;
)
