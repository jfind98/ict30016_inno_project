# Suricata ruleset — Optimized targeting for dos_hping3.sh
# Target: --syn --flood --rand-source and --udp --flood --rand-source

# SECTION 1: INSTANT SIGNATURE MATCHES (No Thresholds)
drop tcp any any -> $HOME_NET [80,443] (msg:"HPING3 ATTACK DROP - Explicit hping3 TCP fingerprint detected"; flags:S,SA; window:512; ttl:64; classtype:attempted-dos; sid:9000001; rev:3;)
drop udp any any -> $HOME_NET 53 (msg:"HPING3 ATTACK DROP - Malicious 0-byte UDP flood to DNS port"; dsize:0; classtype:attempted-dos; sid:9000002; rev:3;)

# SECTION 2: DESTINATION RATE MITIGATION (Countering --rand-source)
alert tcp any any -> $HOME_NET 80 (msg:"DOS ATTACK ALERT - High Volume SYN Rate on HTTP 80"; flags:S,SA; detection_filter:track by_dst, count 200, seconds 1; classtype:attempted-dos; sid:9000003; rev:3;)
drop tcp any any -> $HOME_NET 80 (msg:"DOS ATTACK DROP - Mitigating HTTP 80 SYN Flood"; flags:S,SA; detection_filter:track by_dst, count 500, seconds 1; classtype:attempted-dos; sid:9000004; rev:3;)
alert tcp any any -> $HOME_NET 443 (msg:"DOS ATTACK ALERT - High Volume SYN Rate on HTTPS 443"; flags:S,SA; detection_filter:track by_dst, count 200, seconds 1; classtype:attempted-dos; sid:9000005; rev:3;)
drop tcp any any -> $HOME_NET 443 (msg:"DOS ATTACK DROP - Mitigating HTTPS 443 SYN Flood"; flags:S,SA; detection_filter:track by_dst, count 500, seconds 1; classtype:attempted-dos; sid:9000006; rev:3;)

# SECTION 3: BACKSTOP CATCH-ALLS
drop tcp any any -> $HOME_NET ![80,443] (msg:"DOS ATTACK DROP - Global SYN Flood mitigation on non-web ports"; flags:S,SA; detection_filter:track by_dst, count 1000, seconds 1; classtype:attempted-dos; sid:9000007; rev:3;)
drop udp any any -> $HOME_NET !53 (msg:"DOS ATTACK DROP - Global UDP Flood mitigation on non-DNS ports"; detection_filter:track by_dst, count 2000, seconds 1; classtype:attempted-dos; sid:9000008; rev:3;)
